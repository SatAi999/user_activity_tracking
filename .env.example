# ── Backend (.env in /backend) ──────────────────────────────────────────────
# MongoDB Atlas connection string
MONGO_URI=mongodb://...

# JWT secret (use a long random string in production)
JWT_SECRET=your_jwt_secret_here

# Port (Railway sets this automatically — leave blank locally and it uses 5000)
PORT=5000

# Your Netlify frontend URL — needed for CORS in production
CLIENT_URL=https://your-app.netlify.app


# ── Frontend (.env in /frontend) ────────────────────────────────────────────
# Your Railway backend URL — set this in Netlify environment variables
# Leave blank locally (the Vite proxy handles /api → localhost:5000)
VITE_API_URL=https://your-app.up.railway.app
